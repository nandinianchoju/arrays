method 1
[3, 3, 9, 9] — after removing duplicates, second largest is 3, not 9 again.
code
arr = [3, 1, 7, 4, 9, 2]

unique = list(set(arr))   # remove duplicates first
unique.sort()              # sort ascending

second_largest = unique[-2]  # second from end

print("Second largest:", second_largest)

method 2
arr = [3, 1, 7, 4, 9, 2]

# Pass 1: find the largest
largest = arr[0]
for num in arr:
    if num > largest:
        largest = num

# Pass 2: find largest that is NOT the largest
second = float('-inf')
for num in arr:
    if num != largest and num > second:
        second = num

print("Second largest:", second)

method 3
arr = [3, 1, 7, 4, 9, 2]

largest = float('-inf')
second  = float('-inf')

for num in arr:
    if num > largest:
        second = largest   # old largest drops to second
        largest = num
    elif num > second and num != largest:
        second = num       # update second if bigger

print("Second largest:", second)

